from typing import TYPE_CHECKING, Callable

if TYPE_CHECKING:
    from .core import LTSeq


class LinkedTable:
    def __len__(self) -> int: ...
    def show(self, n: int = ...) -> None: ...
    def filter(self, predicate: Callable) -> LinkedTable | LTSeq: ...
    def select(self, *cols: str | Callable) -> LTSeq: ...
    def derive(self, mapper: Callable) -> LinkedTable: ...
    def sort(self, *key_exprs: str | Callable) -> LinkedTable: ...
    def slice(self, start: int, end: int) -> LinkedTable: ...
    def distinct(self, key_fn: Callable | None = ...) -> LinkedTable: ...
    def link(
        self,
        target_table: LTSeq,
        on: Callable,
        as_: str,
        join_type: str = ...,
    ) -> LinkedTable: ...
