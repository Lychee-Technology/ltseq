/target
*.so
.DS_Store
*.log
__pycache__/
*.bak

# Benchmark data files (large parquet datasets)
benchmarks/data/*.parquet
# Atomic-write temp files (e.g. hits_sorted.parquet.tmp) left by an interrupted COPY
benchmarks/data/*.parquet.tmp
# DuckDB spill directory used by prepare_data.py's out-of-core sort
benchmarks/data/.duckdb_spill/

# Benchmark run outputs (regenerated by bench scripts)
benchmarks/results.json
benchmarks/clickbench_results.json

# autoresearch generated results (flamegraphs, run summaries)
benchmarks/autoresearch/results/
.opencode/
.claude/
build/

# autoresearch controller worktrees (local scratch)
.worktrees/
.vscode/
libltseq_core.dylib.dSYM/
